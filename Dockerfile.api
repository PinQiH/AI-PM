FROM python:3.11-slim

# 設定工作目錄
WORKDIR /app

# PST import 依賴 readpst 與 rarfile 解壓縮依賴 unrar-free
RUN apt-get update \
    && apt-get install -y --no-install-recommends pst-utils postgresql-client unrar-free \
    && rm -rf /var/lib/apt/lists/*

# 複製 requirements.txt
COPY requirements.txt .

# 安裝依賴
RUN pip install --no-cache-dir -r requirements.txt

# 複製應用程式程式碼
COPY . .

# 預設執行指令 (API)
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
