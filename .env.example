# 資料庫
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# OpenAI
OPENAI_API_KEY=

# Web Admin
WEB_ADMIN_PASSWORD=

# Browser 對外呼叫 API 的正式網址
# 開發環境範例：http://localhost:8000
# 正式環境範例：https://elenb.gogotest.xyz/api
PUBLIC_API_BASE_URL=http://localhost:8000

# API CORS 允許來源，使用逗號分隔
# 開發環境範例：http://localhost:8501,http://127.0.0.1:8501
# 正式環境範例：https://elenb.gogotest.xyz
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Docker Compose Profiles
# 正式環境若要啟用 Telegram polling：COMPOSE_PROFILES=telegram
# 開發環境不需要時：刪除此行或留空
COMPOSE_PROFILES=

# Docker Compose 專案名稱
# 建議正式環境設定為 elenb，避免容器、network、volume 名稱與其他系統混淆
COMPOSE_PROJECT_NAME=elenb

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_DEFAULT_PROJECT_ID=

# 互動超過幾分鐘未回覆就自動停止對話
TELEGRAM_IDLE_TIMEOUT_MINUTES=30
