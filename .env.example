# 資料庫
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# OpenAI
OPENAI_API_KEY=

# Web Admin
WEB_ADMIN_PASSWORD=

# Docker Compose Profiles
# 需要啟用 Telegram 監聽時：COMPOSE_PROFILES=telegram
# 不需要 Telegram 監聽時：刪除此行或留空
COMPOSE_PROFILES=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_DEFAULT_PROJECT_ID=

# 互動超過幾分鐘未回覆就自動停止對話
TELEGRAM_IDLE_TIMEOUT_MINUTES=30

# 提供給 Telegram 使用者可開啟來源檔案的 API 對外位址
PUBLIC_API_BASE_URL=http://localhost:8000
